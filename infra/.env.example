# PostgreSQL
POSTGRES_USER=cofr
POSTGRES_PASSWORD=cofr
POSTGRES_DB=cofr
POSTGRES_PORT=5432

# S3 Database Backups (required for backup/restore system)
# Add these to infra/.prod.env on your production VPS:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BACKUP_S3_BUCKET=
# BACKUP_S3_ENDPOINT=  # Optional, defaults to https://s3.amazonaws.com
# BACKUP_S3_REGION=us-east-1  # Default
# BACKUP_S3_PREFIX=postgres  # Default
