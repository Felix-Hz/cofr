# Database Configuration (must match infra/.env credentials)
DATABASE_URL=postgresql://cofr:cofr@postgres:5432/cofr

# JWT Configuration
JWT_SECRET=your-generated-secret-min-32-chars

# Encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# API Configuration
API_PORT=5784
ENV=dev

# Sentry (empty = disabled)
SENTRY_DSN=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# Email — Resend (empty = ConsoleProvider for dev/test)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=hello@cofr.cash
EMAIL_FROM_NAME=cofr
RESEND_WEBHOOK_SECRET=

# S3 - export file storage (empty = disabled, exports still work via temp files)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=cofr-data

# URLs
# Dev (Docker via Caddy): http://localhost:8080/api / http://localhost:8080
# Dev Google redirect URI: http://localhost:8080/api/auth/oauth/google/callback
# Prod: https://cofr.cash / https://cofr.cash
API_URL=http://localhost:8080/api
FRONTEND_URL=http://localhost:8080
