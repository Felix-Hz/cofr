# Cofr Environment Variables
# Each app has its own .env file. Copy this as reference, then create:
#   infra/.env        (PostgreSQL credentials)
#   apps/server/.env
#   apps/tg-bot/.env
#   apps/client/.env

# ── infra (PostgreSQL) ────────────────────────────────────
# See infra/.env.example — POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, POSTGRES_PORT
# DATABASE_URL in app .env files must match these values.

# ── apps/server (FastAPI) ─────────────────────────────────
DATABASE_URL=postgresql://cofr:cofr@postgres:5432/cofr
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_BOT_NAME=your_bot_name
JWT_SECRET=your-generated-secret-min-32-chars
ENCRYPTION_KEY=
API_PORT=5784
ENV=production
# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Email — Resend (empty = ConsoleProvider for dev/test)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=hello@cofr.cash
EMAIL_FROM_NAME=Cofr
RESEND_WEBHOOK_SECRET=
# URLs
# Dev (Docker via Caddy): http://localhost:8080/api / http://localhost:8080
# Dev Google redirect URI: http://localhost:8080/api/auth/oauth/google/callback
# Prod: https://cofr.cash / https://cofr.cash
API_URL=http://localhost:8080/api
FRONTEND_URL=http://localhost:8080

# ── apps/tg-bot (Go Telegram Bot) ────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
DATABASE_URL=postgresql://cofr:cofr@postgres:5432/cofr
ENV=production

# ── apps/client (React Router / Bun) ─────────────────────
VITE_API_BASE_URL=/api
